{
  "name": "dantojitos-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:ts && npm run build:css",
    "build:ts": "esbuild static/ts/*.ts --bundle=false --format=esm --target=es2020 --outdir=static/js/compiled --sourcemap --minify-whitespace",
    "build:css": "tailwindcss -i static/css/tailwind.input.css -o static/css/compiled/tailwind.css --minify",
    "watch": "concurrently \"npm run watch:ts\" \"npm run watch:css\"",
    "watch:ts": "esbuild static/ts/*.ts --bundle=false --format=esm --target=es2020 --outdir=static/js/compiled --sourcemap --watch",
    "watch:css": "tailwindcss -i static/css/tailwind.input.css -o static/css/compiled/tailwind.css --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.0",
    "concurrently": "^8.0.0",
    "esbuild": "^0.20.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
